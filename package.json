{
  "name": "elamar-equipment",
  "version": "9.0.0",
  "description": "ELAMAR – برنامج إدارة المعدات",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.elamar.equipment",
    "productName": "ELAMAR",
    "directories": { "output": "dist" },
    "files": ["main.js", "src/**/*"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "src/icon.ico"
    },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
